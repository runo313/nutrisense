#%RAML 1.0 DataType
type: object
displayName: WearableIngest
properties:
  point_metrics:
    type: array
    description: List of point metric records to ingest
    items: !include point-metric-type.raml
  sleep_sessions:
    type: array
    description: List of sleep session records to ingest
    items: !include sleep-session-type.raml
  workouts:
    type: array
    description: List of workout records with nested statistics to ingest
    items: !include workout-type.raml