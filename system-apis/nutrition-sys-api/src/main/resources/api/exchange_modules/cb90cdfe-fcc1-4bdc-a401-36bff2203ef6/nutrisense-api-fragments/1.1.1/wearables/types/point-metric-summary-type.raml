#%RAML 1.0 DataType
type: object
displayName: PointMetricSummary
properties:
  metric_type:
    type: string
    description: Canonical metric type these aggregates apply to, e.g. heart_rate, steps
  start_date:
    type: datetime
    description: Start of the window these aggregates cover
  average:
    type: number
    description: Average value across all records in the requested window
  min:
    type: number
    description: Minimum recorded value in the requested window
  max:
    type: number
    description: Maximum recorded value in the requested window
  count:
    type: integer
    description: Total number of records in the requested window
  unit:
    type: string
    description: Unit of measurement for the aggregated values, e.g. bpm, kg
example:
  metric_type: "heart_rate"
  start_date: "2023-09-01T00:00:00Z"
  end_date: "2023-09-30T23:59:59Z"
  average: 72.4
  min: 45.0
  max: 183.0
  count: 1284
  unit: "bpm"