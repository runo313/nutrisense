#%RAML 1.0 DataType

type: object
description: Response for food search results.
properties:
  totalResults:
    type: integer
    description: Total number of foods matching the search query
  foods:
    type: array
    items: !include food-summary-type.raml 
    description: List of matching foods up to the requested limit.

example: !include ../examples/food-summary-example.raml