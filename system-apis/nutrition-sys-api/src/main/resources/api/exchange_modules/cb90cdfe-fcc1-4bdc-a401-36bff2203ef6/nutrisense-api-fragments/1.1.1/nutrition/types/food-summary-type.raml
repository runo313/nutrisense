#%RAML 1.0 DataType
type: object
description: Abbreviated food record returned by search results.
properties:
  foodId: 
    type: integer
    description: Unique food identifier, maps to USDA FDC ID
  name: 
    type: string
    description: Common name of the food
  category: 
    type: string
    description: USDA food category 
  servingSizeG: 
    type: number
    description: Reference serving size in grams. Defaults to 100g

    