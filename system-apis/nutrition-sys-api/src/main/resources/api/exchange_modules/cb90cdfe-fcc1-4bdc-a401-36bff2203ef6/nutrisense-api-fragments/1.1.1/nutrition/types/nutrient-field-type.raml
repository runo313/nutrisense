#%RAML 1.0 DataType
type: string
displayName: Nutrient Field
description: Canonical nutrient field names used to filter nutrient responses
enum:
  - energyKcal
  - proteinG
  - carbohydratesG
  - dietaryFiberG
  - sugarsG
  - totalFatG
  - saturatedFatG
  - sodiumMg
  - potassiumMg
  - calciumMg
  - ironMg
  - vitaminCMg
  - vitaminDMcg
  - vitaminB12Mcg
  - magnesiumMg
  - zincMg
