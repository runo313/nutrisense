<?xml version="1.0" encoding="UTF-8"?>

<mule xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:munit="http://www.mulesoft.org/schema/mule/munit" xmlns:munit-tools="http://www.mulesoft.org/schema/mule/munit-tools"
	xmlns="http://www.mulesoft.org/schema/mule/core" xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
	xsi:schemaLocation="
		http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
		http://www.mulesoft.org/schema/mule/munit http://www.mulesoft.org/schema/mule/munit/current/mule-munit.xsd
		http://www.mulesoft.org/schema/mule/munit-tools  http://www.mulesoft.org/schema/mule/munit-tools/current/mule-munit-tools.xsd">
	<munit:config name="meal-deletes-suite.xml" />
	<munit:test name="should_delete_meal_and_return_204" doc:id="9e8d6f55-2965-4b00-b82c-cf385b00127c" >
		<munit:behavior >
			<munit-tools:mock-when doc:name="check meals exist" doc:id="df9fcdc8-0e32-46a8-a2e5-48466b8450cf" processor="db:select" >
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="b685c72f-1a45-4cad-94da-433862c3df65" attributeName="doc:id" />
				</munit-tools:with-attributes>
			</munit-tools:mock-when>
			<munit-tools:mock-when doc:name="Mock Update" doc:id="dd46b6b5-a63d-4503-944e-4c2b843dc854" processor="db:update">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="169a88a5-255c-4346-b45b-4ba75eb7486c" attributeName="doc:id" />
				</munit-tools:with-attributes>
			</munit-tools:mock-when>
			<munit-tools:mock-when doc:name="Mock Update meal" doc:id="ef47e482-e1f9-4630-b11c-69e7d0f86e55" processor="db:update">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="413aa91b-f68c-4fdf-8559-88cb4fa78a8c" attributeName="doc:id" />
				</munit-tools:with-attributes>
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution >
			<munit:set-event doc:name="Set Event" doc:id="22fef954-e1c2-44c2-a456-681092233f2d" >
				<munit:attributes value='#[%dw 2.0&#10;output application/java&#10;---&#10;{&#10;  uriParams: {&#10;    userId: "55445",&#10;    mealId: "335c71bb-a167-4160-935e-1c8413f39764"&#10;  },&#10;  queryParams: {}&#10;}]' />
			</munit:set-event>
			<set-variable value='#[[{meal_id: "335c71bb-a167-4160-935e-1c8413f39764"}]]' doc:name="Set Variable" doc:id="4a7dacb2-783d-4091-afd0-6c0abaea08f0" variableName="meal_id" />
			<set-variable value='#[[{&#10;	"itemId": "2e2881ad-394b-438c-8465-09d36db9cf30",&#10;	"portionId": 118808,&#10;	"portionAmount": 1.5,&#10;	"quantityG": 74.55&#10;}]]' doc:name="Set Variable1" doc:id="faf2d2cb-43b8-4695-93bc-33d454b3f43e" variableName="item_response" />
			<flow-ref doc:name="delete:\meals\(mealId)" doc:id="fbf1fa61-8fa0-44de-8177-84af2899fb1a" name="delete:\users\(userId)\meals\(mealId):meal-log-sys-api-config"/>
		</munit:execution>
		<munit:validation >
			<munit-tools:assert-that doc:name="Assert http status is 204" doc:id="e177f1f3-ee7b-466d-b8f1-3b799575b902" is="#[MunitTools::equalTo(204)]" expression="#[vars.httpStatus]"/>
			<munit-tools:assert-that doc:name="Assert that payload is null" doc:id="0f393606-8f2c-452c-aca0-a97f574b398d" expression="#[payload]" is="#[MunitTools::equalTo(null)]" />
		</munit:validation>
	</munit:test>
	<munit:test name="should_delete_meal_item_and_return_204" doc:id="851f6abf-7a7f-4ed8-9d8b-d0464701c098" >
		<munit:behavior >
