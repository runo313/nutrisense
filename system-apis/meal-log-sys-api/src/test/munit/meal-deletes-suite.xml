				<munit:attributes value='#[%dw 2.0&#10;output application/java&#10;---&#10;{&#10;  uriParams: {&#10;    userId: "55445",&#10;    mealId: "335c71bb-a167-4160-935e-1c8413f39764",&#10;    itemId: "8f6c2a34-b03d-49c0-a30a-c347d2183317"&#10;  },&#10;  queryParams: {}&#10;}]' />
			</munit:set-event>
			<set-variable value='#[[{meal_id: "335c71bb-a167-4160-935e-1c8413f39764"}]]' doc:name="Set Variable" doc:id="fadd669c-045a-4a67-a1ca-a99b29ee5d65" variableName="meal_id" />
			<set-variable value='#[[{&#10;	"itemId": "2e2881ad-394b-438c-8465-09d36db9cf30",&#10;	"portionId": 118808,&#10;	"portionAmount": 1.5,&#10;	"quantityG": 74.55&#10;}]]' doc:name="Set Variable1" doc:id="0252d009-796a-4aca-88e5-d1bdc077c056" variableName="item_response" />
			<flow-ref doc:name="Flow Reference" doc:id="c63949dd-5de8-48e4-978e-5a3ca53496e4" name="delete:\users\(userId)\meals\(mealId)\items\(itemId):meal-log-sys-api-config"/>
		</munit:execution>
		<munit:validation >
			<munit-tools:assert-that doc:name="Assert http status is 204" doc:id="ae3f967d-4577-4fdc-99a2-00a0a56bca32" expression="#[vars.httpStatus]" is="#[MunitTools::equalTo(204)]" />
			<munit-tools:assert-that doc:name="Assert that payload is null" doc:id="0f3f38f8-da49-46e9-95db-d04a3799d22d" expression="#[payload]" is="#[MunitTools::equalTo(null)]" />
		</munit:validation>
	</munit:test>

</mule>
