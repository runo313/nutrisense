	<munit:test name="should_return_400_for_invalid_item_mode" doc:id="e8dc20a7-ee74-4fc1-9db0-b50106ba22de">
		<munit:execution >
			<munit:set-event doc:name="Set Event" doc:id="7269e1bf-4247-4d0d-898d-e9200de8745f" >
				<munit:payload value='#[%dw 2.0&#10;output application/java&#10;---&#10;{&#10;  mealType: "breakfast",&#10;  consumedAt: "2026-07-13T08:00:00-04:00",&#10;  items: [&#10;    {foodId: 747448, portionId: 118808, portionAmount: 1.5, quantityG: 150.0}&#10;  ]&#10;}]' />
				<munit:attributes value='#[%dw 2.0&#10;output application/java&#10;---&#10;{&#10;  uriParams: {userId: "55445"},&#10;  queryParams: {}&#10;}]' />
			</munit:set-event>
			<flow-ref doc:name="post:\meals\(mealId)" doc:id="906189e2-3316-4bd5-bd59-ec27d9d18c0c" name="post:\users\(userId)\meals:application\json:meal-log-sys-api-config" />
		</munit:execution>
		<munit:validation >
			<munit-tools:assert-that doc:name="Assert that http status 400" doc:id="fac6c5d2-2d23-4b87-bd82-289e0fe12d64" expression="#[vars.httpStatus]" is="#[MunitTools::equalTo(400)]" message="http status should be 400"/>
			<munit-tools:assert-that doc:name="Assert code" doc:id="c5d95a01-e516-4cf8-9839-a930f9ccb457" expression="#[payload.code]" is='#[MunitTools::equalTo("MEAL-400")]'/>
		</munit:validation>
	</munit:test>
