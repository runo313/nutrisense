		</munit:execution>
		<munit:validation >
			<munit-tools:assert-that doc:name="Assert that http status 20" doc:id="7466f8ed-92d8-4672-8e67-93ddaffc56a9" expression="#[vars.httpStatus]" is="#[MunitTools::equalTo(200)]" />
			<munit-tools:assert-that doc:name="Assert that meal id equals " doc:id="9651df97-b8c8-4494-9af7-63ac8ef14c7d" expression="#[payload.mealId]" is="#[MunitTools::equalTo('335c71bb-a167-4160-935e-1c8413f39764')]" />
			<munit-tools:assert-that doc:name="Assert that userId equals " doc:id="fa313662-ee3a-457b-93aa-012406ab52f6" expression="#[payload.userId]" is="#[MunitTools::equalTo('55445')]" />
			<munit-tools:assert-that doc:name="Assert items not empty" doc:id="218a96eb-2d6d-432e-9e45-21bfeb2cfc88" expression="#[payload.items]" is="#[MunitTools::not(MunitTools::isEmpty())]" />
		</munit:validation>
	</munit:test>
