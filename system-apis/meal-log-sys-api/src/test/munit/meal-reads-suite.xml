	<munit:config name="meal-reads-suite.xml" />
	<munit:test name="should_return_meals_for_date_200" doc:id="320874f9-6b76-4010-8bfb-e9c6e5343283">
		<munit:behavior >
			<munit-tools:mock-when doc:name="Mock when" doc:id="6da74d26-a22f-4f52-aa16-0ec6e2527ac0" processor="db:select">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="6eb77221-9821-48db-90ce-e0bf69b51540" attributeName="doc:id" />
				</munit-tools:with-attributes>
				<munit-tools:then-return >
					<munit-tools:payload value='#[[&#10;  {&#10;    "meal_id": "335c71bb-a167-4160-935e-1c8413f39764",&#10;    "user_id": "55445",&#10;    "meal_type": "breakfast",&#10;    "consumed_at": "2026-07-13 12:00:00+00",&#10;    "meal_logged_at": "2026-07-16 01:01:01+00",&#10;    "item_id": "8f6c2a34-b03d-49c0-a30a-c347d2183317",&#10;    "food_id": 747448,&#10;    "portion_id": 118808,&#10;    "portion_amount": 1.5,&#10;    "quantity_g": 234.0,&#10;    "item_logged_at": "2026-07-16 01:01:01+00"&#10;  }&#10;]]' />
				</munit-tools:then-return>
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution >
			<munit:set-event doc:name="Set Event" doc:id="42127da0-a809-48ef-947f-710a4029328f" >
				<munit:attributes value='#[%dw 2.0&#10;output application/java&#10;---&#10;{&#10;  uriParams: {userId: "55445"},&#10;  queryParams: {&#10;    date: "2026-07-13",&#10;    timezone: "America/New_York"&#10;  }&#10;}]' />
			</munit:set-event>
			<flow-ref doc:name="get meals" doc:id="25951454-440e-4c0f-a7cf-962465c4b044" name="get:\users\(userId)\meals:meal-log-sys-api-config"/>
		</munit:execution>
		<munit:validation >
			<munit-tools:assert-that doc:name="Assert that http status 200" doc:id="85948c0d-74ab-4204-89c0-2fe688c9ddf9" expression="#[vars.httpStatus]" is="#[MunitTools::equalTo(200)]" />
			<munit-tools:assert-that doc:name="Assert that payload  counts &gt; 0" doc:id="a2945bd0-511c-40b1-a3e8-ff71610730e8" expression="#[payload.counts]" is="#[MunitTools::greaterThan(0)]" />
			<munit-tools:assert-that doc:name="Assert meals not empty" doc:id="fb74fe0b-2d34-4519-915d-0782aa6f424e" expression="#[payload.meals]" is="#[MunitTools::not(MunitTools::isEmpty())]"/>
		</munit:validation>
	</munit:test>
	<munit:test name="should_return_empty_meals_200" doc:id="b60769b4-15de-4682-860a-f03bcc03f4e5">
		<munit:behavior >
