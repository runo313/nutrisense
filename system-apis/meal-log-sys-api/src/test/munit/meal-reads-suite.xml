		</munit:behavior>
		<munit:execution >
			<munit:set-event doc:name="Set Event" doc:id="85f0c7f0-165a-47e8-8edf-674da705c8a1" >
				<munit:attributes value='#[%dw 2.0&#10;output application/java&#10;---&#10;{&#10;  uriParams: {userId: "55445"},&#10;  queryParams: {&#10;    date: "2026-07-13",&#10;    timezone: "America/New_York"&#10;  }&#10;}]' />
			</munit:set-event>
			<flow-ref doc:name="get meals" doc:id="7d54e9a4-f672-4241-9359-9cc5c2f49f8f" name="get:\users\(userId)\meals:meal-log-sys-api-config" />
		</munit:execution>
		<munit:validation >
			<munit-tools:assert-that doc:name="Assert that http status 404" doc:id="810ee117-2740-4360-92c8-c8db08194c97" expression="#[vars.httpStatus]" is="#[MunitTools::equalTo(404)]" />
			<munit-tools:assert-that doc:name="Assert that payload equals 0" doc:id="8f5b3dbb-4045-4dcd-bb72-a714814c9dc3" expression="#[payload.counts]" is="#[MunitTools::equalTo(null)]" />
			<munit-tools:assert-that doc:name="Assert that meals equals 0" doc:id="ec60c355-63aa-409c-9e01-8d2aa2d21317" expression="#[sizeOf(payload.meals)]" is="#[MunitTools::equalTo(null)]" />
		</munit:validation>
	</munit:test>
